# .env.example - Copy this file to .env and fill in your MySQL credentials.
# When DB_USER and DB_PASSWORD are left blank the application falls back to
# JSON file storage (no MySQL required for development).

# MySQL connection settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=competitive_intel

# Optional API keys for enhanced news coverage
GNEWS_API_KEY=
NEWSAPI_KEY=
